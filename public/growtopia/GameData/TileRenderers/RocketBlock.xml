<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer itemID="ITEM_ID_ROCKET_BLOCK">
	<Data>
		<Sprite name="s_tile" fileName="game/tiles_page17.rttex" textureSize="32" frame="5,18" />
		<Sprite name="rocket_Sprite" fileName="game/particles12.rttex" textureSize="32" frame="31,12"/>
		<Sprite name="trail_Sprite" fileName="game/particles12.rttex" textureSize="32" frame="30,12"/>
		<Sprite name="hit_Sprite" fileName="game/particles12.rttex" textureSize="32" frame="29,12"/>

		<Animations>
			<SpriteAnimation name="a_tile1" sprite="s_tile" isLoop="true" animTime="400" playOnState="IsOn.True">
				<Frame>6,18</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="a_tile2" playOnState="IsOn.False" sprite="s_tile">
				<Frame>5,18</Frame>
			</SpriteAnimation>
		</Animations>

		<StateMachines>
			<StateMachine name="IsOn">
				<States>
					<State name="False"/>
					<State name="True"/>
				</States>
				<Transitions>
					<Transition to="True" from="False">
						<Condition>
							<IsTileFlagActive operatorType="Equal">TILE_FLAG_IS_ON</IsTileFlagActive>
						</Condition>
					</Transition>

					<Transition to="False" from="True">
						<Condition>
							<IsTileFlagActive operatorType="NotEqual">TILE_FLAG_IS_ON</IsTileFlagActive>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
			<StateMachine name="Facing">
				<States>
					<State name="Left"/>
					<State name="Right"/>
				</States>
				<Transitions>
					<Transition to="Right" from="Left">
						<Condition>
							<IsFacingLeft>false</IsFacingLeft>
						</Condition>
					</Transition>

					<Transition to="Left" from="Right">
						<Condition>
							<IsFacingLeft>true</IsFacingLeft>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>

		<ParticleSystems>
			<ParticleSystem name="particle_right" secondary="trail_particle">
				<Emitter>
					<Random name="particlesPerEmission" min="1" max="2"/>
					<Set name="infParticles">true</Set>
					<Set name="lifeTime">0.6</Set>
					<Set name="offset">10,-8</Set>
					<Set name="emissionInterval">0.4</Set>
					<Set name="rgbTint">1, 1, 1, 1</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">rocket_Sprite</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Random name="lifeTime" min="1.5" max="2.0"/>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>0.9, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Random name="offset" min="-6,-6" max="6,6" />
					<Random name="initialVelocity" min="50, -80" max="75, -80" />
					<Random name="finalVelocity" min="50, 60" max="75, 90" />
					<Set name="interpolateVelocity">true</Set>
					<Set name="rotateWithVelocity">true</Set>
					<OnFinish>
						<ParticleSystemName>hit_particle</ParticleSystemName>
					</OnFinish>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="particle_left" secondary="trail_particle">
				<Emitter>
					<Random name="particlesPerEmission" min="1" max="2"/>
					<Set name="infParticles">true</Set>
					<Set name="lifeTime">0.6</Set>
					<Set name="offset">10,-8</Set>
					<Set name="emissionInterval">0.4</Set>
					<Set name="rgbTint">1, 1, 1, 1</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">rocket_Sprite</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Random name="lifeTime" min="1.5" max="2.0"/>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>0.9, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Random name="offset" min="-6,-6" max="6,6" />
					<Random name="initialVelocity" min="-50, -80" max="-75, -80" />
					<Random name="finalVelocity" min="-50, 60" max="-75, 90" />
					<Set name="interpolateVelocity">true</Set>
					<Set name="rotateWithVelocity">true</Set>
					<OnFinish>
						<ParticleSystemName>hit_particle</ParticleSystemName>
					</OnFinish>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="trail_particle">
				<Emitter>
					<Set name="lifeTime">2</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">80</Set>
					<Set name="emissionInterval">0.075</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">trail_Sprite</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.5</Set>
					<Set name="initialScale">1,1</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.1, 0.35</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="initialVelocity">0,0</Set>

				</Particle>
			</ParticleSystem>
			<ParticleSystem name="hit_particle">
				<Emitter>
					<Set name="offset">0,0</Set>
					<Set name="lifeTime">0</Set>
					<Set name="particlesPerEmission">20</Set>
					<Set name="delayTimer">0.0</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">hit_Sprite</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Set name="lifeTime">1</Set>
					<RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="10,30"/>
					<Set name="useGravity">true</Set>
					<Set name="gravityVector">0, 50</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0.5</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 3,3</KeyFrame>
						<KeyFrame>0.33, 1,1</KeyFrame>
						<KeyFrame>1, 1,1</KeyFrame>
					</Curve>
				</Particle>
			</ParticleSystem>
		</ParticleSystems>
	</Data>
	<RenderRules>
		<Render>
			<SpriteRender name="s_tile" blend="PREMULTIPLIED_ALPHA" />
		</Render>
		<RenderInWorldSpaceFront>
			<Group onState="Facing.Right">
				<ParticleSystemUpdate name="particle_right" onState="IsOn.True"/>
			</Group>
			<Group onState="Facing.Left">
				<ParticleSystemUpdate name="particle_left" onState="IsOn.True"/>
			</Group>
		</RenderInWorldSpaceFront>
	</RenderRules>
</ItemRenderer>